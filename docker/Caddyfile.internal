{$CADDY_SITE_ADDRESS} {
	tls internal

	root * /srv
	encode zstd gzip

	@stream path /api/v1/stream/*
	reverse_proxy @stream backend:8080 {
		flush_interval -1
	}

	@api path /api/*
	reverse_proxy @api backend:8080

	@health path /health
	reverse_proxy @health backend:8080

	try_files {path} /index.html
	file_server
}
