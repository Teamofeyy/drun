# На VPS: скопировать как .env рядом с docker-compose.yml

DOCKER_USER=ваш_логин_docker_hub
JWT_SECRET=придумайте-длинный-секрет

# UI: снаружи 80/443 (на ноуте по умолчанию 3000 и 30443 — см. docker-compose.yml)
# FRONTEND_HTTP=80
# FRONTEND_HTTPS_BIND=443

# Caddy по IP (внутренний конфиг)
# CADDY_CONFIG_PATH=/etc/caddy/Caddyfile.internal
# CADDY_SITE_ADDRESS=ваш.ip.или.домен

# POSTGRES_PASSWORD=если не дефолтный infrahub
