# Секрет первичной регистрации (совпадает с AGENT_ENROLLMENT_SECRET на мастере)
INFRAHUB_ENROLLMENT_SECRET={{ infrahub_agent_enrollment_secret }}
# Архитектура узла (ansible_facts.architecture) — уходит в БД при register и для выбора musl-артефакта при self-update
INFRAHUB_AGENT_CPU_ARCH={{ ansible_facts['architecture'] }}
# Опционально: INFRAHUB_HEARTBEAT_SECS, INFRAHUB_POLL_FALLBACK_SECS (0 = без HTTP poll при WS). URL master — в unit (ExecStart --server=).
