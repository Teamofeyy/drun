DATABASE_URL=postgres://infrahub:infrahub@127.0.0.1:5432/infrahub
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
BIND=0.0.0.0:8080
AGENT_MAX_CONCURRENT_TASKS=1
AGENT_ENROLLMENT_SECRET=dev-enrollment-change-me
# Схлопывание SSE dashboard notify (мс, 50–2000)
DASHBOARD_NOTIFY_DEBOUNCE_MS=250
INFRAHUB_AGENT_RELEASE_BASE=https://github.com/Teamofeyy/drun/releases/download/stable
# За reverse proxy: увеличьте read timeout для длинных соединений (SSE /api/v1/stream/dashboard и WS /api/v1/agent/ws), например nginx proxy_read_timeout 3600s; для WS нужны Upgrade и Connection.
# Агент (на ноде): INFRAHUB_POLL_FALLBACK_SECS=60 по умолчанию; 0 — только WebSocket, без периодического GET tasks/next.
